# Copy this file to .env and fill in the values for your local backend.

# Backend
HOST=127.0.0.1
PORT=17817

# Optional backend token. When set, every /api/* route requires
# Authorization: Bearer <BACKEND_API_TOKEN>. Store the same value in the
# extension Settings tab for users who should call the backend.
BACKEND_API_TOKEN=

# Comma-separated browser origins allowed to call the backend from web pages.
# Include the CMS origin and the internal extension download origin when needed.
CORS_ALLOWED_ORIGINS=https://usifhqtsagrqt01.melaleuca.net,http://localhost:17817,http://127.0.0.1:17817

# Comma-separated extension URL schemes allowed for extension popup/full-page calls.
# Firefox temporary add-ons use changing moz-extension origins, so scheme-level
# allowance is more practical than exact extension origins for this MVP.
CORS_ALLOWED_EXTENSION_SCHEMES=chrome-extension,moz-extension

# Local SQLite store. Relative paths resolve from the project root.
SQLITE_FILE=backend/data/store.sqlite

# Optional one-time migration source. If the SQLite database is empty and this
# JSON file exists, the backend imports its requests, translations, and events.
STORE_FILE=backend/data/store.json

# Leave false until the live Smartling adapter is implemented.
SMARTLING_ENABLED=false

# Poll active Smartling jobs for cancelled/completed status while the backend is running.
# Set SMARTLING_SYNC_ENABLED=false to disable, or change the interval as needed.
SMARTLING_SYNC_ENABLED=true
SMARTLING_SYNC_INTERVAL_MINUTES=60
SMARTLING_SYNC_LOOKBACK_DAYS=30
SMARTLING_SYNC_MIN_CHECK_INTERVAL_MINUTES=5

# New CMS Product Copy projects.
# Prefer project tokens, so each project can have its own identifier and secret.
SMARTLING_US_PROJECT_ID=
SMARTLING_US_USER_IDENTIFIER=
SMARTLING_US_USER_SECRET=
SMARTLING_US_WORKFLOW_ID=

SMARTLING_CA_PROJECT_ID=
SMARTLING_CA_USER_IDENTIFIER=
SMARTLING_CA_USER_SECRET=
SMARTLING_CA_WORKFLOW_ID=

SMARTLING_EU_PROJECT_ID=
SMARTLING_EU_USER_IDENTIFIER=
SMARTLING_EU_USER_SECRET=
SMARTLING_EU_WORKFLOW_ID=

# Optional shared fallback. Use only if you intentionally create one account-level token
# that can access both projects.
SMARTLING_USER_IDENTIFIER=
SMARTLING_USER_SECRET=

# Optional callback base URL for Smartling webhooks.
# For local development this usually needs a tunnel URL, not 127.0.0.1.
SMARTLING_CALLBACK_BASE_URL=
